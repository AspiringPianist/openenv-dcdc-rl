TEXT -2976 -328 Left 2 !.tran 100u
TEXT -1696 32 Left 2 ;Dead time circuit
TEXT -624 64 Left 1 ;The A6 buff/inverter sets the deadtime.
TEXT -624 88 Left 1 ;Remember if you want the duty cycle of the converter to be 70% or Vout=0.7.Vin,
TEXT -624 152 Left 1 ;VA and VB will be inverted versions.
TEXT -624 120 Left 1 ;set the duty cycle of the input source to be 70%.
TEXT -1096 -192 Left 2 !.include models_292p.txt
TEXT -2984 -264 Left 2 !* ===========================================================\n* FINAL FREQUENCY SWEEP + LOSS BREAKDOWN\n* ===========================================================\n \n.param Tstart = 0.7u\n.param Tend   = 1u\n \n.param Ron_PMOS = 0.1499\n.param Ron_NMOS = 0.3749\n \n.param T = 30n\n.param D = 0.716\n.param Rload = 4\n.param deadtime = 0.01n\n \n* -------- INPUT / OUTPUT POWER --------\n.meas TRAN Pin  AVG -V(vdd)*I(V2) FROM {Tstart} TO {Tend}\n.meas TRAN Pout AVG  V(n004)*I(R1) FROM {Tstart} TO {Tend}\n.meas TRAN Efficiency PARAM (Pout/Pin)*100\n.meas TRAN P_Total_Loss PARAM Pin-Pout\n \n* -------- MOS TOTAL LOSS --------\n.meas TRAN P_M9_total  AVG V(n003,vdd)*Id(M9) FROM {Tstart} TO {Tend}\n.meas TRAN P_M10_total AVG V(n003)*Id(M10)    FROM {Tstart} TO {Tend}\n \n* -------- MOS CONDUCTION LOSS --------\n.meas TRAN P_M9_cond  AVG (Id(M9)^2)*Ron_PMOS FROM {Tstart} TO {Tend}\n.meas TRAN P_M10_cond AVG (Id(M10)^2)*Ron_NMOS FROM {Tstart} TO {Tend}\n \n* -------- MOS SWITCHING LOSS --------\n.meas TRAN P_M9_sw  PARAM P_M9_total  - P_M9_cond\n.meas TRAN P_M10_sw PARAM P_M10_total - P_M10_cond\n \n* -------- DRIVER LOSS --------\n.meas TRAN P_drivers AVG -V(vdd)*(Is(M1)+Is(M3)+Is(M5)+Is(M7)) FROM {Tstart} TO {Tend}\n \n* -------- INDUCTOR DCR LOSS --------\n.meas TRAN P_Ind_DCR AVG I(L1)^2*0.093 FROM {Tstart} TO {Tend}\n \n* -------- CAPACITOR ESR LOSS --------\n.meas TRAN P_C_ESR AVG I(C1)^2*0.0171 FROM {Tstart} TO {Tend}
